{
    // --- Skill development workspace ---
    // Each skill lives under skills/<skill-name>/SKILL.md
    // Global registration: ~/.agents/skills/<skill-name> -> symlink to this workspace

    "files.associations": {
        "*.skill": "markdown",
        "registry.yaml": "yaml",
        "registry-tags.yaml": "yaml"
    },

    "editor.rulers": [100],
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 100,

    // Trim trailing whitespace in SKILL.md and scripts
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    // Search / explorer exclusions
    "search.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/node_modules": true,
        "**/.git": true
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true
    },

    // Python: point to the workspace venv if one is created
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

    // Markdown: enable linting and preview
    "markdown.validate.enabled": true,

    // Recommended extensions prompt (non-blocking)
    "extensions.ignoreRecommendations": false
}
